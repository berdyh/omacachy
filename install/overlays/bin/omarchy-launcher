#!/usr/bin/env bash
set -euo pipefail

if command -v walker >/dev/null 2>&1; then
  exec walker run
elif command -v wofi >/dev/null 2>&1; then
  exec wofi --show drun
elif command -v rofi >/dev/null 2>&1; then
  exec rofi -show drun
fi

echo "No supported launcher found (walker/wofi/rofi)." >&2
exit 1
