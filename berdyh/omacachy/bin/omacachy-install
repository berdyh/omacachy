#!/usr/bin/env bash
set -euo pipefail

# Wrapper-only CLI for the omacachy overlay on top of berdyh/omarchy-upstream.
script_name="$(basename "$0")"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UPSTREAM_ROOT="${UPSTREAM_ROOT:-${repo_root}/../omarchy-upstream}"

case "${script_name}" in
  omacachy-install) target="install.sh" ;;
  omacachy-update) target="update.sh" ;;
  omacachy-sync-upstream) target="scripts/sync-upstream.sh" ;;
  omacachy-apply-patches) target="scripts/apply-patches.sh" ;;
  omacachy-power-status)
    if [[ -x "${UPSTREAM_ROOT}/install/compat/cachyos/power-status.sh" ]]; then
      target="install/compat/cachyos/power-status.sh"
    else
      target="install/compat/cachyos/power.sh"
      set -- status "$@"
    fi
    ;;
  omacachy-power-profile)
    if [[ -x "${UPSTREAM_ROOT}/install/compat/cachyos/power-profile.sh" ]]; then
      target="install/compat/cachyos/power-profile.sh"
    else
      target="install/compat/cachyos/power.sh"
      set -- profile "$@"
    fi
    ;;
  *) echo "Unknown command: ${script_name}" >&2; exit 2 ;;
esac

exec "${UPSTREAM_ROOT}/${target}" "$@"
